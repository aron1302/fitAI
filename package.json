{
  "name": "fitai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "AI-powered fitness app: dashboard, workout plan, diet plan, and AI coach.",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "cross-env PORT=3001 node --watch server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "backup": "node scripts/backup.js",
    "gen:icons": "node scripts/gen-icons.js",
    "import:gifs": "node scripts/import-gifs.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.5",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "libsql": "^0.5.29",
    "nodemailer": "^9.0.2",
    "qrcode": "^1.5.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.9.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "esbuild@0.25.12": true
  }
}
