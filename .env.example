# Copy this file to .env and paste your Anthropic API key to enable real AI.
# Without a key, the app falls back to a built-in rule-based planning engine.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override the server port (default 3001)
PORT=3001

# Exercise demo photos come from the free, public-domain free-exercise-db
# dataset — NO API key and NO quota. Each looked-up photo is cached permanently
# in the app's own database (served from your origin, offline-capable). They're
# fetched lazily on first view; run `npm run import:gifs` once to pre-populate
# the common exercises. Only set these to point at your own mirror of the data:
# FREE_EXERCISE_DB_URL=
# FREE_EXERCISE_IMG_BASE=

# ---- Security / production (see DEPLOY.md) ----
# REQUIRED in production: a long random secret (>=32 chars). The server refuses
# to start in production without it. Generate one with: openssl rand -hex 32
# In development a temporary one is auto-generated if unset.
SESSION_SECRET=

# Set to "production" when deploying (enables secure cookies, HSTS, strict checks).
# NODE_ENV=production

# Set to 1 (or a hop count) when running behind a TLS-terminating reverse proxy,
# so the server sees the real client IP and marks cookies Secure.
# TRUST_PROXY=1

# Comma-separated browser origins allowed to call the API with credentials.
# Empty = same-origin only (the default for the bundled SPA).
# ALLOWED_ORIGINS=

# Failed-login lockout policy (optional; defaults shown).
# MAX_LOGIN_ATTEMPTS=8
# LOCKOUT_MINUTES=15

# Path to the SQLite database file (optional; default ./fitai.db)
# DB_PATH=

# ---- Email (verification & password reset) ----
# Public base URL used to build email links. Set to your real origin in
# production (e.g. https://fitai.example.com). Defaults to http://localhost:PORT.
# APP_URL=

# SMTP transport. If unset, verification/reset emails are printed to the server
# log instead of being sent (handy for local development).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# Or a single connection URL instead of the fields above:
# SMTP_URL=smtp://user:pass@smtp.example.com:587
# From address on outgoing mail:
# MAIL_FROM=FitAI <no-reply@fitai.example.com>
