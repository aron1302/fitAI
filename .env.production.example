# Production environment for FitAI.
#
# On Fly.io you generally DON'T use this file directly. Non-secret values live in
# fly.toml's [env] block; secrets are set with `fly secrets set KEY=value` (they
# are encrypted and injected as env vars at runtime). This file documents every
# variable in one place and doubles as a template for non-Fly hosts.
#
# Anything marked SECRET must go through `fly secrets set`, never fly.toml.

# ---- Core (already set in fly.toml [env]) ----
NODE_ENV=production
PORT=3001
TRUST_PROXY=1
DB_PATH=/data/fitai.db
BACKUP_DIR=/data/backups
# Public origin used to build email links (custom domain or https://<app>.fly.dev)
APP_URL=https://your-app.fly.dev
# Comma-separated cross-origin SPAs allowed to call the API with credentials.
# Leave empty for same-origin (the default for the bundled SPA).
ALLOWED_ORIGINS=

# ---- SECRET: session signing (REQUIRED) ----
# The server refuses to boot in production without a strong value (>=32 chars).
# Generate: openssl rand -hex 32   (or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=

# ---- SECRET: AI provider (optional — omit to use the rule-based engine) ----
ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# Exercise demo photos use the free, public-domain free-exercise-db (no key, no
# quota); pre-populate with `npm run import:gifs`. Nothing to configure here.

# ---- SECRET: email / SMTP (required for verification & password reset) ----
# Without SMTP, those emails only print to the server log.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Or a single URL instead of the four fields above:
# SMTP_URL=smtp://user:pass@smtp.example.com:587
MAIL_FROM=FitAI <no-reply@your-domain.example>

# ---- SECRET: Litestream off-site backup (optional) ----
# Set to enable continuous replication of the SQLite DB to object storage.
# LITESTREAM_REPLICA_URL=s3://your-bucket/fitai
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ---- Auth lockout policy (optional; defaults shown) ----
# MAX_LOGIN_ATTEMPTS=8
# LOCKOUT_MINUTES=15
